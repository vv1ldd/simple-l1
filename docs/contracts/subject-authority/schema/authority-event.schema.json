{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simplel1.online/contracts/subject-authority/schema/authority-event.schema.json",
  "title": "SL1 Subject Authority Event",
  "description": "Canonical semantic-class input to the subject authority evaluator. This object claims authority to change a scoped subject authority graph.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "type",
    "subject",
    "authority_domain",
    "action",
    "target",
    "proof",
    "timestamp",
    "previous_state_reference"
  ],
  "properties": {
    "schema_version": {
      "const": "simple-l1.subject_authority.authority_event.v1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^ae_[a-f0-9]{16,64}$"
    },
    "type": {
      "const": "authority_event"
    },
    "subject": {
      "$ref": "#/$defs/subjectAddress"
    },
    "authority_domain": {
      "enum": [
        "identity",
        "device",
        "finance",
        "organization",
        "application"
      ]
    },
    "action": {
      "enum": [
        "genesis",
        "bind_controller",
        "revoke_controller",
        "rotate_key",
        "bind_device",
        "transfer_device",
        "grant_capability",
        "revoke_capability",
        "accept_claim",
        "bind_relationship"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "recipient": {
      "anyOf": [
        { "$ref": "#/$defs/subjectAddress" },
        { "type": "null" }
      ]
    },
    "capability": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        { "type": "null" }
      ]
    },
    "scope": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        { "type": "null" }
      ]
    },
    "expires_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        { "type": "null" }
      ]
    },
    "proof": {
      "$ref": "#/$defs/proof"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "previous_state_reference": {
      "anyOf": [
        { "$ref": "#/$defs/sha256Ref" },
        { "type": "null" }
      ]
    },
    "causal_parents": {
      "type": "array",
      "items": { "$ref": "#/$defs/eventId" },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "$defs": {
    "subjectAddress": {
      "type": "string",
      "pattern": "^sl1:(id|device|agent|org):[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "eventId": {
      "type": "string",
      "pattern": "^ae_[a-f0-9]{16,64}$"
    },
    "sha256Ref": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "controller"
      ],
      "properties": {
        "type": {
          "enum": [
            "signed_intent",
            "legacy_event_bridge",
            "genesis_authority"
          ]
        },
        "controller": {
          "$ref": "#/$defs/subjectAddress"
        },
        "signature": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            { "type": "null" }
          ]
        },
        "legacy_event_id": {
          "anyOf": [
            { "$ref": "#/$defs/legacyEventId" },
            { "type": "null" }
          ]
        },
        "evidence_hash": {
          "anyOf": [
            { "$ref": "#/$defs/sha256Ref" },
            { "type": "null" }
          ]
        }
      }
    },
    "legacyEventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    }
  }
}
