{
  "manifest_version": 3,
  "name": "Simple-L1 Sovereign Authenticator",
  "version": "0.1.0",
  "description": "Cross-platform hardware-backed identity for the Simple-L1 network.",
  "permissions": ["storage", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start"
    }
  ]
}
